# Secret key for Gemini server-side API calls (do NOT use NEXT_PUBLIC_ prefix)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated allowed origins for /api/chat (supports entries with optional /*)
# Example: https://your-site.vercel.app/*,http://localhost:3000/*
ALLOWED_ORIGINS=https://your-site.vercel.app/*,http://localhost:3000/*
